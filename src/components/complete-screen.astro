---
import { getTranslations } from "@/i18n/utilities";
import { ui } from "@/i18n/ui";

const currentLang = (Astro.currentLocale ?? "en") as "en" | "es";
const t = getTranslations(currentLang);

const features = [
  {
    icon: "user-circle",
    title: t.complete.features.profile.title,
    description: t.complete.features.profile.description,
    paths: [
      "M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0",
      "M9 10a3 3 0 1 0 6 0a3 3 0 1 0 -6 0",
      "M6.168 18.849a4 4 0 0 1 3.832 -2.849h4a4 4 0 0 1 3.834 2.855",
    ],
  },
  {
    icon: "calendar-check",
    title: t.complete.features.stays.title,
    description: t.complete.features.stays.description,
    paths: [
      "M11.5 21h-5.5a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v6",
      "M16 3v4",
      "M8 3v4",
      "M4 11h16",
      "M15 19l2 2l4 -4",
    ],
  },
  {
    icon: "shield-lock",
    title: t.complete.features.security.title,
    description: t.complete.features.security.description,
    paths: [
      "M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3",
      "M11 11a1 1 0 1 0 2 0a1 1 0 1 0 -2 0",
      "M12 12l0 2.5",
    ],
  },
];
---

<div
  class="h-full flex flex-col justify-between grad safe-area-inset"
  style="--l: #86e0f9; --m: #016692; --d: #022648;"
>
  <div class="h-full p-8 flex flex-col justify-between max-w-md mx-auto">
    <div class="flex flex-col gap-8">
      <div class="flex justify-center">
        <div
          class="tpc-typography-body-s min-h-20 min-w-20 text-white rounded-full flex justify-center items-center"
          style="
					background: var(
						--Bg-Accent-Weak,
						rgba(255, 255, 255, 0.12)
					);
				"
        >
          JD
        </div>
      </div>

      <div class="text-white text-center space-y-1.5">
        <p class="tpc-typography-title-m">
          {t.complete.welcome}
        </p>
        <p class="tpc-typography-body-m">
          {t.complete.description}
        </p>
      </div>

      <div
        class="rounded-tpc-container-s p-4 text-white flex flex-col"
        style="
							background: var(
								--Bg-Hover,
								rgba(255, 255, 255, 0.08)
							);
							backdrop-filter: blur(20px);
							-webkit-backdrop-filter: blur(20px);
						"
      >
        {
          features.map((feature) => (
            <div class="py-3 flex gap-2.5">
              <div
                class="w-10 h-10 flex justify-center items-center rounded-full shrink-0"
                style="background: var(--Bg-Hover, rgba(255, 255, 255, 0.08));"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class={`icon icon-tabler icons-tabler-outline icon-tabler-${feature.icon}`}
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  {feature.paths.map((d) => (
                    <path d={d} />
                  ))}
                </svg>
              </div>
              <div>
                <p class="tpc-typography-label-s">{feature.title}</p>
                <p class="tpc-typography-body-xs">{feature.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <button id="done-btn" class="py-4 px-5.5 bg-white rounded-full">
      {t.complete.doneButton}
    </button>
  </div>
</div>

<script>
  document.getElementById("done-btn")?.addEventListener("click", () => {
    window.PalaceApp.emit("navigate", { to: "faceid" });
  });
</script>
