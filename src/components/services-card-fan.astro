---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface ServiceCard {
  title: string;
  image: ImageMetadata;
}

interface Props {
  cards: ServiceCard[]; // expects 5, center is index 2
  width?: number;
  height?: number;
}

const { cards, width = 126, height = 160 } = Astro.props;

const LAYOUT = [
  { tx: -160, ty: 30, rot: -22, scale: 0.92, opacity: 0.55 },
  { tx: -90, ty: 10, rot: -12, scale: 0.96, opacity: 0.95 },
  { tx: 0, ty: 0, rot: 0, scale: 1, opacity: 1 },
  { tx: 90, ty: 10, rot: 12, scale: 0.96, opacity: 0.95 },
  { tx: 160, ty: 30, rot: 22, scale: 0.92, opacity: 0.55 },
];

// Render order: back to front [0, 4, 1, 3, 2]
const renderOrder = [0, 4, 1, 3, 2];
---

<div class="card-fan-container" style={`height: ${height + 40}px;`}>
  {
    renderOrder.map((i) => {
      const card = cards[i];
      const target = LAYOUT[i];
      return (
        <div
          class="fanned-card"
          data-index={i}
          style={`
            width: ${width}px;
            height: ${height}px;
            --tx: ${target.tx}px;
            --ty: ${target.ty}px;
            --rot: ${target.rot}deg;
            --scale: ${target.scale};
            --opacity: ${target.opacity};
          `}
        >
          <div class="card-inner">
            <Image
              src={card.image}
              alt={card.title}
              class="card-image"
              loading="eager"
            />
            <p class="card-label">{card.title}</p>
          </div>
        </div>
      );
    })
  }
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll(".fanned-card");
    cards.forEach((card) => {
      // Reset animation
      const htmlCard = card as HTMLElement;
      htmlCard.style.animation = "none";
      // Force reflow
      void htmlCard.offsetHeight;
      // Start animation
      htmlCard.style.animation = "";
    });
  });
</script>

<style>
  .card-fan-container {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .fanned-card {
    position: absolute;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    animation: fanOut 1000ms cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
    opacity: var(--opacity);
    transform: translate(0, 0) rotate(0deg) scale(0.85);
  }

  @keyframes fanOut {
    from {
      opacity: var(--opacity);
      transform: translate(0, 0) rotate(0deg) scale(0.85);
    }
    to {
      opacity: var(--opacity);
      transform: translate(var(--tx), var(--ty)) rotate(var(--rot))
        scale(var(--scale));
    }
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    border-radius: 18px;
    padding: 14px;
    background: #fff;
    overflow: hidden;
  }

  .card-image {
    width: 64px;
    height: 64px;
    margin-top: 12px;
    object-fit: contain;
  }

  .card-label {
    font-size: 14px;
    font-family: "DMSans", sans-serif;
    color: #102137;
    margin-bottom: 8px;
    text-align: center;
  }
</style>
