---
import "@/assets/styles/index.css";
import { ClientRouter } from "astro:transitions";

const currentLang = Astro.currentLocale ?? "en";
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Palace ID</title>
    <ClientRouter />
  </head>
  <body data-theme="palace">
    <slot />
  </body>
</html>

<style is:global>
  /* View Transitions - Fade animation */
  @keyframes fade-out {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Aplicar fade a todas las transiciones */
  ::view-transition-old(root) {
    animation: 300ms cubic-bezier(0.4, 0, 0.2, 1) both fade-out;
  }

  ::view-transition-new(root) {
    animation: 300ms cubic-bezier(0.4, 0, 0.2, 1) both fade-in;
  }
</style>

<script is:inline>
  /**
   * PalaceApp - Global namespace and event bus
   * Prevents naming collisions and provides centralized communication
   */
  window.PalaceApp = {
    version: "1.0.0",

    /**
     * Listen to app events
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {Function} callback - Event handler
     */
    on(event, callback) {
      window.addEventListener(`palace:${event}`, callback);
    },

    /**
     * Emit app events
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {any} detail - Event data
     */
    emit(event, detail) {
      window.dispatchEvent(new CustomEvent(`palace:${event}`, { detail }));
    },

    /**
     * Remove event listener
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {Function} callback - Event handler to remove
     */
    off(event, callback) {
      window.removeEventListener(`palace:${event}`, callback);
    },
  };
</script>
