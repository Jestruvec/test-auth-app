---
import "@/assets/styles/index.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
  </head>
  <body data-theme="palace">
    <slot />
  </body>
</html>

<style is:global>
  body {
    opacity: 0;
    animation: fadeIn 0.5s ease-in forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>

<script is:inline>
  /**
   * PalaceApp - Global namespace and event bus
   * Prevents naming collisions and provides centralized communication
   */
  window.PalaceApp = {
    version: "1.0.0",

    /**
     * Listen to app events
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {Function} callback - Event handler
     */
    on(event, callback) {
      window.addEventListener(`palace:${event}`, callback);
    },

    /**
     * Emit app events
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {any} detail - Event data
     */
    emit(event, detail) {
      window.dispatchEvent(new CustomEvent(`palace:${event}`, { detail }));
    },

    /**
     * Remove event listener
     * @param {string} event - Event name (will be prefixed with 'palace:')
     * @param {Function} callback - Event handler to remove
     */
    off(event, callback) {
      window.removeEventListener(`palace:${event}`, callback);
    },

    /**
     * Navigate with fade transition
     * @param {string} url - URL to navigate to
     */
    navigate(url) {
      const body = document.body;
      body.style.transition = "opacity 0.5s";
      body.style.opacity = "0";

      setTimeout(() => {
        window.location.href = url;
      }, 500);
    },
  };
</script>
